{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "giant-header/header",
  "title": "Site Header",
  "category": "theme",
  "icon": "admin-site-alt3",
  "description": "Site header with logo, navigation, and search",
  "attributes": {
    "logo": {"type": "object", "default": {"url": "", "id": null, "alt": ""}},
    "backgroundColor": {"type": "string", "default": "transparent"},
    "contactText": {"type": "string", "default": "Contact us"},
    "contactUrl": {"type": "string", "default": "#contact"},
    "contactDisplayMode": {"type": "string", "default": "label"},
    "contactIcon": {"type": "object", "default": {"url": "", "id": null, "alt": ""}},
    "contactIconWidth": {"type": "string", "default": "32"},
    "containerWidth": {"type": "string", "default": "1200"}
  },
  "supports": {"html": false, "align": ["full"]},
  "textdomain": "giant-header",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
